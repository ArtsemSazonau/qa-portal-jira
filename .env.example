# Scoped (read-only) Atlassian API token. Create it at https://id.atlassian.com ->
# Security -> API tokens -> "Create API token with scopes". Grant only:
#   read:jira-user  (GET /myself)
#   read:jira-work  (GET /filter/{id}, POST /search/jql)
JIRA_API_TOKEN=your_jira_token
JIRA_EMAIL=your_email
# Your site's cloudId. Required: all Jira calls route through the Atlassian gateway
# https://api.atlassian.com/ex/jira/<JIRA_CLOUD_ID>. Find it by opening
# https://<your-site>.atlassian.net/_edge/tenant_info in a browser.
JIRA_CLOUD_ID=your_cloud_id
# Site URL, kept only as a convenient pointer to where you look up the cloudId.
# It is no longer used for request routing.
JIRA_BASE_URL=your_jira_instance_url
QATRACKER_LOGIN=
QATRACKER_PASSWORD=
